# --- Server (Vercel project → Settings → Environment Variables) ---

# Resend (parts quote emails)
RESEND_API_KEY=re_xxxxxxxx
QUOTE_TO_EMAIL=parts@yourcompany.com
RESEND_FROM=Parts Quote <onboarding@resend.dev>
QUOTE_SEND_CUSTOMER_COPY=false

# Admin login (server-side only — not exposed to the browser)
ADMIN_USERNAME=rebar
ADMIN_PASSWORD=Madden19!
# Random secret for signing admin sessions — generate with: openssl rand -hex 32
ADMIN_SECRET=replace-with-a-long-random-string

# Postgres (auto-set when you add Neon/Postgres storage in Vercel → Storage)
POSTGRES_URL=postgresql://...

# Blob storage for uploaded part photos (auto-set when you add Vercel Blob → Storage)
BLOB_READ_WRITE_TOKEN=vercel_blob_...

# --- Front-end (local dev) ---
# Point local Vite at your deployed Vercel site so /api routes work during `npm run dev`:
# VITE_QUOTE_API_URL=https://your-site.vercel.app
#
# Or run everything locally with API + database:
# npm run dev:vercel
