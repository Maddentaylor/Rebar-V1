# --- Server (Vercel project → Settings → Environment Variables) ---
# Get an API key at https://resend.com
RESEND_API_KEY=re_xxxxxxxx

# Inbox that receives each parts quote (your team)
QUOTE_TO_EMAIL=parts@yourcompany.com

# "From" address — use a domain you verify in Resend for production.
# With onboarding@resend.dev, Resend only allows sending to your own test email until you add a domain.
RESEND_FROM=Parts Quote <onboarding@resend.dev>

# Send a branded confirmation to the customer (needs a verified Resend "from" domain for most inboxes)
QUOTE_SEND_CUSTOMER_COPY=false

# --- Front-end (local dev) ---
# If you use `npm run dev`, put your deployed Vercel URL here so /api is proxied to production:
# VITE_QUOTE_API_URL=https://your-site.vercel.app
